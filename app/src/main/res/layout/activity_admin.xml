<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:text="Admin Panel"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Manage authorized NFC UIDs"
        android:textSize="14sp"
        android:textColor="#4A90D9"
        android:layout_marginBottom="32dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="NFC UID"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etUID"
        android:hint="Enter NFC UID"
        android:background="@drawable/rounded_input"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAddUID"
        android:text="Add UID"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2D3A8C"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnRemoveUID"
        android:text="Remove UID"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C0392B"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:text=""
        android:textSize="14sp"
        android:textColor="#2D3A8C"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>