<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- RED ADMIN HERO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#932339"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back,"
                    android:textColor="#FFCCCC"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- LOGOUT BUTTON -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Sign Out"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#6B1111"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>
        </LinearLayout>

        <!-- STAT PILLS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#66000000"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatStudents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Students"
                    android:textColor="#FFCCCC"
                    android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#66000000"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatRooms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lab Rooms"
                    android:textColor="#FFCCCC"
                    android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#66000000"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">

                <TextView
                    android:id="@+id/tvStatLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logs Today"
                    android:textColor="#FFCCCC"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- FORM SECTION -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ADD / REMOVE CARD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add / Remove Student"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- NFC UID -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NFC CARD UID"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#666666"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etUID"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g. 90541437"

                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/rounded_input"
                        android:layout_marginBottom="12dp"/>

                    <!-- STUDENT NAME -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STUDENT NAME"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#666666"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etStudentName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g. John Doe"

                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/rounded_input"
                        android:layout_marginBottom="12dp"/>

                    <!-- STUDENT ID -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STUDENT ID"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#666666"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g. 40012345"

                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/rounded_input"
                        android:layout_marginBottom="16dp"/>

                    <!-- BUTTONS ROW -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnAddUID"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="＋ Add"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:backgroundTint="#932339"
                            android:layout_marginEnd="8dp"/>

                        <Button
                            android:id="@+id/btnRemoveUID"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="− Remove"
                            android:textColor="#932339"
                            android:textStyle="bold"
                            android:backgroundTint="#FDECEA"/>
                    </LinearLayout>

                    <!-- STATUS MESSAGE -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="#932339"
                        android:gravity="center"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ACCESS LOGS SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Access Logs"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/llAccessLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No logs yet"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- OCCUPANCY SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lab Occupancy"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lab 101"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <TextView
                            android:id="@+id/tvOccupancyCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvOccupancyBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— / —"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#932339"
                        android:background="#FDECEA"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>